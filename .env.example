# Database
TIMESCALE_DB_HOST=localhost
TIMESCALE_DB_USER=user
TIMESCALE_DB_PORT=5432
TIMESCALE_DB_PASSWORD=password
TIMESCALE_DB_DATABASE=database

# Use Docker
DOCKER_MODE=false
DOCKER_INTERFACE_NAME=eth0

# TapDevice
TAP_INTERFACE_NAME=tap0
TAP_IP=192.168.0.150
TAP_MASK=24

# IPDS Setting
# 検知のみ行いたい場合: IDS_ENABLED=true, IDS_LOG=true, IPS_ENABLED=false
# 検知して防止も行う場合: IDS_ENABLED=true, IDS_LOG=true, IPS_ENABLED=true
# 完全に無効にする場合: IDS_ENABLED=false
IDS_ENABLED=true
IDS_LOG=true
IPS_ENABLED=true